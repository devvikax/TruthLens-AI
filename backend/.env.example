PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/truthlens
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cloud Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI/FactCheck Keys
# Get a free GEMINI_API_KEY from Google AI Studio (https://aistudio.google.com/) - 100% free with no credit card required
GEMINI_API_KEY=your_gemini_api_key_here
FACTCHECK_API_KEY=your_google_factcheck_api_key_here
# Get a Brave Search API Key from Brave Developer Portal (https://api.search.brave.com/)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# OpenRouter Configuration (Optional Alternative)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash:free
